{
  "name": "ytapis-electron",
  "version": "1.0.0",
  "description": "YouTube Search Desktop App powered by ytapis-core",
  "author": "geethudinoyt",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "ytapis.electron.app",
    "productName": "ytapis-search",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      "node_modules/ytapis-core/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "dependencies": {
    "ytapis-core": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
