{
    "name":  "ytapis-core",
    "version":  "1.0.0",
    "description":  "Search YouTube and get video metadata ??? no API key required",
    "author":  "geethudinoyt",
    "keywords":  [
                     "youtube",
                     "search",
                     "scraper",
                     "metadata",
                     "innertube",
                     "oembed"
                 ],
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/pgboyahpgr-commits/ytapis.git"
                   },
    "license":  "MIT",
    "main":  "dist/index.js",
    "module":  "dist/index.mjs",
    "types":  "dist/index.d.ts",
    "exports":  {
                    ".":  {
                              "types":  "./dist/index.d.ts",
                              "import":  "./dist/index.mjs",
                              "require":  "./dist/index.js"
                          }
                },
    "files":  [
                  "dist"
              ],
    "scripts":  {
                    "build":  "tsup src/index.ts --format cjs,esm --dts --clean",
                    "test":  "node -e \"require(\u0027./dist/index.js\u0027).search(\u0027cats\u0027).then(r =\u003e console.log(\u0027OK:\u0027, r.length, \u0027results\u0027))\"",
                    "prepublishOnly":  "npm run build"
                },
    "dependencies":  {

                     },
    "devDependencies":  {
                            "tsup":  "^8.4.0",
                            "typescript":  "^5.7.0"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0"
                }
}
